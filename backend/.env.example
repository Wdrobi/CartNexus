PORT=5000
NODE_ENV=development

# ---------------------------------------------------------------------------
# XAMPP (Windows) — MySQL / MariaDB
# ---------------------------------------------------------------------------
# Control Panel থেকে MySQL Start করুন। ডিফল্ট:
#   Host:     127.0.0.1
#   Port:     3306
#   User:     root
#   Password: খালি (আপনি পাসওয়ার্ড দিলে নিচে লিখুন)
# ডাটাবেস তৈরি: db/schema.sql ও db/seed.sql চালান (নিচে ধাপ দেখুন)
# ---------------------------------------------------------------------------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cartnexus

# JWT — লগইন টোকেন (যেকোনো দীর্ঘ র্যান্ডম স্ট্রিং; প্রোডে শক্তিশালী রাখুন)
JWT_SECRET=change-me-to-a-long-random-string

# ---------------------------------------------------------------------------
# Storefront chat assistant (optional — works without AI using rule + DB search)
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# CHAT_MODEL=gpt-4o-mini
# Public site origin for product links in chat replies (optional in dev)
# FRONTEND_ORIGIN=http://localhost:5173
