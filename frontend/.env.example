# Optional: backend origin when the app is not served with a Vite proxy to /api.
# Example: http://localhost:5000  (no trailing slash)
# VITE_API_URL=

# Footer “Contact us”, CTA contact button, floating support chat → WhatsApp when set (digits only, with country code).
# Example BD: 8801712345678
# VITE_WHATSAPP_NUMBER=
# Optional first message:
# VITE_WHATSAPP_PREFILL=Hello CartNexus

# Optional storefront fallbacks when admin store settings are empty or /api/store-settings is unavailable.
# Full URLs or hostnames (https:// added automatically). Example: facebook.com/yourpage
# VITE_SOCIAL_FACEBOOK_URL=
# VITE_SOCIAL_INSTAGRAM_URL=
# VITE_SOCIAL_YOUTUBE_URL=
# VITE_SOCIAL_OTHER_URL=
# VITE_MESSENGER_URL=
# VITE_STORE_PHONE=
# VITE_STORE_EMAIL=
